<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — AuctionXI</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{
  --bg:#111827;--surface:#1f2937;--surface2:#27364b;--border:#3d5068;
  --accent:#f59e0b;--text:#f1f5f9;--muted:#94a3b8;
  --green:#22c55e;--red:#ef4444;--blue:#60a5fa;--yellow:#eab308;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
nav{background:var(--surface);border-bottom:2px solid var(--accent);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;color:var(--accent);}
.nav-right{display:flex;gap:10px;align-items:center;}
.user-name{font-size:14px;color:var(--muted);}
.btn{padding:8px 18px;border-radius:6px;border:none;cursor:pointer;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:14px;transition:all 0.15s;}
.btn-primary{background:var(--accent);color:#000;}.btn-primary:hover{background:#fbbf24;}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);}.btn-ghost:hover{color:var(--text);}
.btn-danger{background:var(--red);color:#fff;}

.container{max-width:900px;margin:0 auto;padding:28px 20px;}
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;}
.page-header h1{font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;}

/* Plan badge */
.plan-badge{display:inline-flex;align-items:center;gap:6px;background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:4px 14px;font-size:13px;font-weight:700;}
.plan-badge.free{color:var(--muted);}
.plan-badge.paid{color:var(--accent);border-color:var(--accent);}

/* Auction cards */
.auctions-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
.auction-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px;cursor:pointer;transition:border-color 0.2s;}
.auction-card:hover{border-color:var(--accent);}
.auction-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.auction-name{font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;}
.status-badge{font-size:11px;font-weight:700;border-radius:4px;padding:2px 8px;text-transform:uppercase;}
.status-setup{background:rgba(96,165,250,0.15);color:var(--blue);}
.status-live{background:rgba(34,197,94,0.15);color:var(--green);}
.status-ended{background:rgba(148,163,184,0.1);color:var(--muted);}
.auction-league{font-size:13px;color:var(--muted);margin-bottom:12px;}
.auction-meta{display:flex;gap:16px;font-size:13px;color:var(--muted);}
.auction-meta span{display:flex;align-items:center;gap:4px;}
.room-code-pill{display:inline-block;background:var(--surface2);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:13px;font-weight:700;color:var(--accent);letter-spacing:2px;margin-top:10px;}
.auction-actions{display:flex;gap:8px;margin-top:14px;padding-top:12px;border-top:1px solid var(--border);}

/* Empty state */
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
.empty-state .icon{font-size:48px;margin-bottom:16px;}
.empty-state h3{font-family:'Rajdhani',sans-serif;font-size:22px;color:var(--text);margin-bottom:8px;}
.empty-state p{font-size:15px;margin-bottom:24px;}

/* Create modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:500;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px;width:100%;max-width:460px;margin:16px;position:relative;max-height:90vh;overflow-y:auto;}
.modal h2{font-family:'Rajdhani',sans-serif;font-size:22px;color:var(--accent);margin-bottom:20px;}
.form-group{display:flex;flex-direction:column;gap:5px;margin-bottom:14px;}
.form-group label{font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:0.4px;}
.form-group input,.form-group select{background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:10px 12px;border-radius:6px;font-size:15px;outline:none;width:100%;}
.form-group input:focus,.form-group select:focus{border-color:var(--accent);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.msg{padding:8px 12px;border-radius:5px;font-size:13px;margin-bottom:10px;}
.msg-error{background:rgba(239,68,68,0.12);border:1px solid var(--red);color:#fca5a5;}
.msg-success{background:rgba(34,197,94,0.1);border:1px solid var(--green);color:#86efac;}

/* Loading */
.loading{text-align:center;padding:60px;color:var(--muted);font-size:16px;}
</style>
</head>
<body>

<nav>
  <div class="logo">🏏 AuctionXI</div>
  <div class="nav-right">
    <span class="user-name" id="userName"></span>
    <div class="plan-badge free" id="planBadge">FREE</div>
    <button class="btn btn-ghost" onclick="signOut()">Sign Out</button>
  </div>
</nav>

<div class="container">
  <div class="page-header">
    <h1>My Auctions</h1>
    <button class="btn btn-primary" onclick="openCreateModal()">+ New Auction</button>
  </div>
  <div id="auctionsList"><div class="loading">Loading your auctions...</div></div>
</div>

<!-- CREATE AUCTION MODAL -->
<div class="modal-overlay" id="createModal">
  <div class="modal">
    <h2>🏏 Create New Auction</h2>
    <div class="form-group">
      <label>Auction / Event Name *</label>
      <input type="text" id="newName" placeholder="e.g. Mohalla Cup 2025 Auction">
    </div>
    <div class="form-group">
      <label>League Name (optional)</label>
      <input type="text" id="newLeague" placeholder="e.g. Hussainabad Premier League">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Default Credits per Team</label>
        <input type="number" id="newCredits" placeholder="100000" value="100000">
      </div>
      <div class="form-group">
        <label>Min Squad Size</label>
        <input type="number" id="newMinSquad" placeholder="11" value="11" min="1">
      </div>
    </div>
    <div id="createMsg"></div>
    <div style="display:flex;gap:10px;margin-top:6px;">
      <button class="btn btn-primary" style="flex:1;padding:11px;" onclick="createAuction()">Create Auction</button>
      <button class="btn btn-ghost" onclick="closeCreateModal()">Cancel</button>
    </div>
  </div>
</div>

<script>
// ── SUPABASE CONFIG ────────────────────────────────────────
const SUPABASE_URL = 'https://ofondrfejzcznxsvpuec.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9mb25kcmZlanpjem54c3ZwdWVjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2MDk5MzMsImV4cCI6MjA4OTE4NTkzM30.5YfDMi0BM07PPJVcp9pfXSg6L5fDldec3usswJQd6no';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let currentUser = null;
let userProfile = null;

// ── INIT ──────────────────────────────────────────────────
(async () => {
  const { data: { session } } = await sb.auth.getSession();
  if (!session) { window.location.href = 'index.html'; return; }
  currentUser = session.user;
  // Load profile
  const { data: profile } = await sb.from('profiles').select('*').eq('id', currentUser.id).single();
  userProfile = profile;
  document.getElementById('userName').textContent = profile?.name || currentUser.email;
  const planBadge = document.getElementById('planBadge');
  if (profile?.plan === 'paid') {
    planBadge.textContent = '⭐ PRO'; planBadge.className = 'plan-badge paid';
  }
  loadAuctions();
})();

// ── LOAD AUCTIONS ─────────────────────────────────────────
async function loadAuctions() {
  const { data: auctions, error } = await sb
    .from('auctions')
    .select(`id, name, league_name, room_code, status, created_at,
             teams(count), players(count)`)
    .eq('owner_id', currentUser.id)
    .order('created_at', { ascending: false });

  const el = document.getElementById('auctionsList');
  if (error) { el.innerHTML = `<div class="msg msg-error">Failed to load auctions.</div>`; return; }
  if (!auctions.length) {
    el.innerHTML = `<div class="empty-state">
      <div class="icon">🏏</div>
      <h3>No auctions yet</h3>
      <p>Create your first auction to get started.</p>
      <button class="btn btn-primary" onclick="openCreateModal()">+ Create Auction</button>
    </div>`; return;
  }
  el.innerHTML = `<div class="auctions-grid">${auctions.map(a => auctionCard(a)).join('')}</div>`;
}

function auctionCard(a) {
  const teams = a.teams?.[0]?.count ?? 0;
  const players = a.players?.[0]?.count ?? 0;
  const date = new Date(a.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
  const statusClass = { setup:'status-setup', live:'status-live', ended:'status-ended' }[a.status] || 'status-setup';
  const statusLabel = { setup:'Setup', live:'🔴 Live', ended:'Ended' }[a.status] || a.status;
  return `<div class="auction-card">
    <div class="auction-card-header">
      <div class="auction-name">${a.name}</div>
      <div class="status-badge ${statusClass}">${statusLabel}</div>
    </div>
    <div class="auction-league">${a.league_name || 'No league name'}</div>
    <div class="auction-meta">
      <span>👥 ${teams} teams</span>
      <span>🏏 ${players} players</span>
      <span>📅 ${date}</span>
    </div>
    <div><span class="room-code-pill">${a.room_code}</span></div>
    <div class="auction-actions">
      <button class="btn btn-primary" style="flex:1;" onclick="openAuction('${a.id}')">
        ${a.status === 'setup' ? '⚙️ Setup' : a.status === 'live' ? '🔴 Open Live' : '📊 View'}
      </button>
      <button class="btn btn-ghost" onclick="copyRoomLink('${a.room_code}')" title="Copy viewer link">🔗 Share</button>
      ${a.status !== 'live' ? `<button class="btn btn-danger" onclick="deleteAuction('${a.id}',event)" title="Delete">🗑</button>` : ''}
    </div>
  </div>`;
}

// ── GENERATE ROOM CODE ────────────────────────────────────
function genRoomCode() {
  return Math.random().toString(36).substring(2, 8).toUpperCase();
}

// ── CREATE AUCTION ────────────────────────────────────────
async function createAuction() {
  const name = document.getElementById('newName').value.trim();
  const league = document.getElementById('newLeague').value.trim();
  const credits = parseFloat(document.getElementById('newCredits').value) || 100000;
  const minSquad = parseInt(document.getElementById('newMinSquad').value) || 11;
  const msgEl = document.getElementById('createMsg');
  if (!name) { msgEl.innerHTML = '<div class="msg msg-error">Enter an auction name</div>'; return; }

  // Freemium check — free users can have max 3 auctions
  if (userProfile?.plan === 'free') {
    const { count } = await sb.from('auctions').select('*', { count: 'exact', head: true }).eq('owner_id', currentUser.id);
    if (count >= 3) {
      msgEl.innerHTML = '<div class="msg msg-error">Free plan allows up to 3 auctions. Upgrade to Pro for unlimited.</div>'; return;
    }
  }

  let roomCode, attempts = 0;
  // Ensure unique room code
  while (attempts < 10) {
    roomCode = genRoomCode();
    const { data } = await sb.from('auctions').select('id').eq('room_code', roomCode).single();
    if (!data) break;
    attempts++;
  }

  const { data, error } = await sb.from('auctions').insert({
    owner_id: currentUser.id,
    name, league_name: league || null,
    room_code: roomCode,
    default_credits: credits,
    min_squad: minSquad,
    status: 'setup'
  }).select().single();

  if (error) { msgEl.innerHTML = `<div class="msg msg-error">${error.message}</div>`; return; }

  // Create initial current_state row
  await sb.from('current_state').insert({ auction_id: data.id });

  closeCreateModal();
  window.location.href = `setup.html?auction=${data.id}`;
}

// ── OPEN AUCTION ──────────────────────────────────────────
function openAuction(id) {
  window.location.href = `auction.html?auction=${id}`;
}

// ── SHARE ─────────────────────────────────────────────────
function copyRoomLink(code) {
  const url = `${window.location.origin}/viewer.html?room=${code}`;
  navigator.clipboard.writeText(url).then(() => alert(`Link copied!\n\n${url}\n\nShare this with your team managers.`));
}

// ── DELETE AUCTION ────────────────────────────────────────
async function deleteAuction(id, e) {
  e.stopPropagation();
  if (!confirm('Delete this auction? All teams, players and sales will be lost.')) return;
  await sb.from('auctions').delete().eq('id', id);
  loadAuctions();
}

// ── MODAL ─────────────────────────────────────────────────
function openCreateModal() {
  document.getElementById('createModal').classList.add('open');
  setTimeout(() => document.getElementById('newName').focus(), 100);
}
function closeCreateModal() {
  document.getElementById('createModal').classList.remove('open');
  document.getElementById('createMsg').innerHTML = '';
}
document.getElementById('createModal').addEventListener('click', function(e) {
  if (e.target === this) closeCreateModal();
});

// ── SIGN OUT ──────────────────────────────────────────────
async function signOut() {
  await sb.auth.signOut();
  window.location.href = 'index.html';
}
</script>
</body>
</html>

